{{- if .WithAuth }}
# --- TokenSmith AuthN/AuthZ ---

# AuthN (JWT validation)
# Required when security.authn.enabled=true
TOKENSMITH_JWKS_URL=http://localhost:3333/.well-known/jwks.json

# AuthZ
# Mode:
#   - off:     disable authorization checks
#   - enforce: deny on policy failure (HTTP 403)
#   - shadow:  allow on policy failure, but emit a structured decision log/event
TOKENSMITH_AUTHZ_MODE=off

# Casbin model + policy sources used by TokenSmith AuthZ integration.
# Generated starter files live under ./authz by default.
TOKENSMITH_CASBIN_MODEL=./authz/model.conf
TOKENSMITH_CASBIN_POLICY=./authz/policy.csv
TOKENSMITH_CASBIN_GROUPING=./authz/grouping.csv
{{- end }}
