# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# LLM Coding Assistant Cruft
.claude
CLAUDE/*
.opencode/

# Goreleaser artifacts
dist/

# Pre-commit temporary directory
.examples.tmp/

# Integration test temporary directories
test/integration/tmp-debug/
test/integration/projects/

# Local build output
bin/


# Generated example projects (keep instruction-only examples tracked)
examples/demo-export/
examples/device-api/
examples/device-inventory/
examples/device-manager/
examples/ent-advanced/
examples/fabrica
examples/fru-service/
examples/myapp/
examples/rack-inventory/
examples/sensor-monitor/
